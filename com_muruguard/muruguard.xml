<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_muruguard</name>
    <author>ZKRANA</author>
    <creationDate>2026-07-09</creationDate>
    <copyright>MIT</copyright>
    <license>MIT</license>
    <authorEmail>zkranao@gmail.com</authorEmail>
    <authorUrl>https://www.linkedin.com/in/zkranadevs/</authorUrl>
    <version>2.4.4</version>
    <description>MuRu Guard Security Scanner. Detects and helps clean malware left behind by the SP Page Builder uploadCustomIcon RCE and related JCE / Helix Ultimate compromises.</description>

    <administration>
        <menu img="class:shield">MuRu Guard</menu>

        <files folder="admin">
            <folder>controllers</folder>
            <folder>models</folder>
            <folder>views</folder>
            <folder>helpers</folder>
            <folder>language</folder>
            <file>access.xml</file>
            <file>config.xml</file>
            <file>controller.php</file>
            <file>muruguard.php</file>
            <file>index.html</file>
        </files>

        <languages folder="admin/language">
            <language tag="en-GB">en-GB/en-GB.com_muruguard.ini</language>
            <language tag="en-GB">en-GB/en-GB.com_muruguard.sys.ini</language>
        </languages>
    </administration>
</extension>
